APP_NAME=SilverBridge Detection Service
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
DEBUG=true

# AiSilverBridgeSky 기준 학습 산출물 (없어도 서버는 기동)
MODEL_PATH=../training/runs/fire_smoke_knife_yolo26/weights/best.pt

CAMERA_SCHEME=http
CAMERA_HOST=192.168.0.18
CAMERA_PORT=4747
CAMERA_PATH_CANDIDATES=/video,/mjpegfeed,/

CONF_THRESHOLD=0.35
IOU_THRESHOLD=0.45

FRAME_WIDTH=1280
FRAME_HEIGHT=720
JPEG_QUALITY=85

INFERENCE_INTERVAL_MS=150
RECONNECT_DELAY_SECONDS=3
FRAME_STALE_SECONDS=5
# 0 = 재연결 시도 상한 없음(로그만). 0 초과 시 상한 도달 후 카운터 리셋·재시도
MAX_RECONNECT_ATTEMPTS=0
CONSECUTIVE_READ_FAILS_BEFORE_RECONNECT=15

LOG_LEVEL=INFO

# 디스플레이 모드
# 0: 디스플레이 안함
# 1: 디스플레이 창 연결(annotated/raw/auto 표시)
# 2: 화면 갈무리(스크린 캡처)로 추론 입력
DISPLAY_MODE=0

# 하위 호환(기존값): true이면 mode=1로 동작
DISPLAY_ENABLED=false
DISPLAY_WINDOW_NAME=SilverBridge Live
# annotated | raw | auto
DISPLAY_SOURCE=annotated

# mode=2 일 때 캡처 영역 (x,y,width,height) — 비우면 메인 화면 전체
SCREEN_CAPTURE_REGION=
